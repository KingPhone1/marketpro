NODE_ENV=production
PORT=3085
HOST=0.0.0.0
DATA_DIR=./data
APP_BASE_URL=https://tu-dominio.com

# Memoria en la nube - Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-privada
SUPABASE_STORE_TABLE=marketpro_store
SUPABASE_STORE_ID=production

# Admin privado
ADMIN_PASSWORD=cambia-esta-contrasena-larga-y-unica

# Mercado Pago - Credenciales reales desde tu panel de desarrollador
# Cuenta de MarketPro: se usa solamente para cobrar anuncios y planes propios
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADO_PAGO_PUBLIC_KEY=APP_USR_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Aplicacion OAuth: permite que cada vendedor conecte su propia cuenta
MERCADO_PAGO_CLIENT_ID=1234567890123456
MERCADO_PAGO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADO_PAGO_OAUTH_REDIRECT_URI=https://tu-dominio.com/api/payments/mercadopago/oauth/callback
# Clave mostrada por Mercado Pago en Webhooks y clave privada de cifrado de MarketPro
MERCADO_PAGO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOKEN_ENCRYPTION_KEY=usa-una-clave-aleatoria-de-al-menos-32-caracteres
MERCADO_PAGO_CURRENCY=USD
